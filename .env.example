# Portable Media Streamer Configuration Example

# Media directory path (absolute or relative)
PMS_PATH=/path/to/media

# Server port
PMS_PORT=8080

# Log level: debug, info, warn, error
PMS_LOG_LEVEL=info

# FFmpeg binary path (optional, defaults to system ffmpeg)
# PMS_FFMPEG_PATH=/usr/bin/ffmpeg

# Database connection settings (advanced)
# PMS_DB_MAX_OPEN_CONNS=25
# PMS_DB_MAX_IDLE_CONNS=5
# PMS_DB_CONN_MAX_LIFETIME=5m
# PMS_DB_CONN_MAX_IDLE_TIME=1m

# Server timeout settings (advanced)
# PMS_READ_TIMEOUT=15s
# PMS_WRITE_TIMEOUT=30s
# PMS_IDLE_TIMEOUT=120s
# PMS_REQUEST_TIMEOUT=30s

# Transcode timeout (advanced)
# PMS_TRANSCODE_TIMEOUT=10m
